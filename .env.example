# Database URL for Prisma
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# NextAuth secret (JWT signing)
NEXTAUTH_SECRET=your_nextauth_secret

# OAuth provider credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify OAuth (NextAuth) credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# NextAuth URL (used for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# Bcrypt salt rounds (default: 10)
BCRYPT_SALT_ROUNDS=10

# Razorpay keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# SMTP (Email) configuration
# Server-side transporter settings
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_smtp_username
MAIL_PASS=your_smtp_password
# Default from address (optional)
# MAIL_FROM="Your Name <no-reply@example.com>"

# Redis connection (for caching, queues)
REDIS_URL=redis://localhost:6379

# Admin email for notifications (server-side)
ADMIN_EMAIL=admin@example.com
# Admin email (client-side for dashboard gating)
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# PostHog analytics (client only)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_public_key_here
NEXT_PUBLIC_POSTHOG_API_HOST=https://app.posthog.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resume download link (client-side)
NEXT_PUBLIC_RESUME_URL=https://your-domain.com/path/to/resume.pdf
